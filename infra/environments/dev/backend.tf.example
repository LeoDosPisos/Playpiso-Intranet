# Renomear para backend.tf e preencher o nome real da storage account
# Ver tarefas manuais: .docs/infra-azure-tarefas-manuais.md (seção 2)
terraform {
  backend "azurerm" {
    resource_group_name  = "playpiso-tfstate-rg"
    storage_account_name = "<STORAGE_ACCOUNT_NAME>"
    container_name       = "tfstate"
    key                  = "playpiso-proposta/dev.terraform.tfstate"
  }
}
